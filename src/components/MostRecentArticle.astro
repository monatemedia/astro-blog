---
import { formatDate } from "../utils";
import type { CollectionEntry } from "astro:content";

const { article } = Astro.props;

interface Props {
  article: CollectionEntry<"blog">;
}

if (!article) {
  return null;
}
---

<div
  class="relative inline-block w-full sm:w-auto cursor-pointer rounded-2xl overflow-hidden group"
>
  <img
    src={"/images/" + article.data.image}
    alt="Article Image"
    class="w-full h-auto rounded-2xl"
  />

  {
    /* 2. THE MASTER LINK EFFECT: 
     This empty <a> tag uses absolute positioning to stretch over the entire card.
     Because it is empty, it can safely sit on layer z-10 without wrapping or nesting anything! */
  }
  <a
    href={"/articles/" + article.id}
    class="absolute inset-0 z-10"
    aria-label={article.data.title}></a>

  <div
    class="absolute inset-0 z-20 flex flex-col items-center justify-center bg-black opacity-80 group-hover:opacity-75 transition duration-300 ease-in-out text-white text-center rounded-2xl pointer-events-none"
  >
    <div class="p-4">
      <h2 class="text-2xl font-semibold sm:text-3xl">
        {article.data.title}
      </h2>

      <p class="text-xl mt-4 text-gray-300">
        {formatDate(article.data.pubDate)}
      </p>

      <div class="flex mt-4 justify-center relative">
        {
          article.data.tags.map((tag: string) => (
            /* ADDED 'pointer-events-auto' directly to each anchor link pill */
            <a
              href={"/articles/tag/" + tag}
              class="pointer-events-auto px-2 py-1 border border-white text-white rounded-full text-xs mr-2 hover:bg-white hover:text-black transition-colors block"
            >
              {tag}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</div>
