---
import MainLayout from "../../../layouts/MainLayout.astro";
import ArticleCard from "../../../components/ArticleCard.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { capitalize } from "../../../utils";

const { tag } = Astro.params;

if (tag === undefined) {
  throw new Error("Tag is required");
}

// Fetch all articles from the "blog" collection
const allBlogArticles: CollectionEntry<"blog">[] = (
  await getCollection("blog")
).sort(
  (a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) =>
    b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const tagArticles = allBlogArticles.filter((article) =>
  article.data.tags?.includes(tag),
);
---

<MainLayout title="Articles, Stories & Tutorials For Tech People">
  <a
    href="/articles"
    class="inline-block
      bg-gray-100
      text-black
      px-5 py-2.5
      rounded-lg
      font-medium
      shadow-sm
      transition-colors
      hover:bg-indigo-700
      mb-6
      hover:text-white"
    >Back To Articles</a
  >
  <h1 class="text-2xl pb-3">#{capitalize(tag)}</h1>

  <!-- Main Grid -->
  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
    <!-- Article Card -->

    {tagArticles.map((article) => <ArticleCard article={article} />)}
  </div>
</MainLayout>
